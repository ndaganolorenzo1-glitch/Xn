# Instagram Credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/instagram_growth
DATABASE_ECHO=False

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
ENCRYPTION_KEY=your-secret-key-change-in-production

# Targeting Configuration
FOLLOW_RATE=50
UNFOLLOW_RATE=50
MIN_FOLLOWER_COUNT=100
MAX_FOLLOWER_COUNT=100000
TARGET_ENGAGEMENT_RATE=0.05

# Content Configuration
POST_ANALYSIS_WINDOW_DAYS=30
OPTIMAL_POSTING_TIMES=9,13,18,21

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Feature Flags
ENABLE_AUTO_FOLLOW=True
ENABLE_AUTO_UNFOLLOW=True
ENABLE_DM_OUTREACH=False
ENABLE_STORY_INTERACTIONS=True
